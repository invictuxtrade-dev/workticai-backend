package services

import (
	"context"
	"database/sql"
	"fmt"
	"os"
	"path/filepath"
	"strings"
	"sync"
	"time"

	"github.com/google/uuid"
	"go.mau.fi/whatsmeow"
	waProto "go.mau.fi/whatsmeow/binary/proto"
	"go.mau.fi/whatsmeow/store/sqlstore"
	"go.mau.fi/whatsmeow/types"
	"go.mau.fi/whatsmeow/types/events"
	waLog "go.mau.fi/whatsmeow/util/log"
	"google.golang.org/protobuf/proto"
	"whatsapp-sales-os-enterprise/backend/internal/models"
)

type BotSession struct {
	ID string; Name string; Status string; Phone string; LastQR string
	StoreDB *sql.DB; Client *whatsmeow.Client; Memory *MemoryService; AI *AIService; Config models.BotConfig; Logger waLog.Logger; MetaDB *sql.DB; Templates *TemplateService
	mu sync.RWMutex
}

type BotManager struct {
	DataDir string; MetaDB *sql.DB; AI *AIService; Templates *TemplateService
	mu sync.RWMutex; Bots map[string]*BotSession
}

func NewBotManager(dataDir string, metaDB *sql.DB, ai *AIService, templates *TemplateService) *BotManager { return &BotManager{DataDir:dataDir, MetaDB:metaDB, AI:ai, Templates:templates, Bots: map[string]*BotSession{}} }

func (m *BotManager) CreateClient(name,email,phone,plan string) (models.Client,error) { if strings.TrimSpace(name)=="" { name="Cliente "+time.Now().Format("20060102150405") }; if strings.TrimSpace(plan)=="" { plan="pro" }; id:=uuid.NewString(); now:=time.Now(); _,err:=m.MetaDB.Exec(`INSERT INTO clients (id, name, email, phone, plan, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, 'active', ?, ?)`, id,name,email,phone,plan,now,now); if err!=nil { return models.Client{}, err }; return m.GetClient(id) }
func (m *BotManager) UpdateClient(c models.Client) error { _, err := m.MetaDB.Exec(`UPDATE clients SET name=?, email=?, phone=?, plan=?, status=?, updated_at=? WHERE id=?`, c.Name,c.Email,c.Phone,c.Plan,c.Status,time.Now(),c.ID); return err }
func (m *BotManager) DeleteClient(id string) error { _, err := m.MetaDB.Exec(`DELETE FROM clients WHERE id=?`, id); return err }
func (m *BotManager) ListClients() ([]models.Client,error) { rows,err:=m.MetaDB.Query(`SELECT id, name, email, phone, plan, status, created_at, updated_at FROM clients ORDER BY created_at DESC`); if err!=nil { return nil, err }; defer rows.Close(); out:=[]models.Client{}; for rows.Next(){ var c models.Client; if err:=rows.Scan(&c.ID,&c.Name,&c.Email,&c.Phone,&c.Plan,&c.Status,&c.CreatedAt,&c.UpdatedAt); err!=nil { return nil, err }; out=append(out,c)}; return out,nil }
func (m *BotManager) GetClient(id string) (models.Client,error) { var c models.Client; err:=m.MetaDB.QueryRow(`SELECT id, name, email, phone, plan, status, created_at, updated_at FROM clients WHERE id=?`,id).Scan(&c.ID,&c.Name,&c.Email,&c.Phone,&c.Plan,&c.Status,&c.CreatedAt,&c.UpdatedAt); return c,err }

func defaultBotConfig(botID, botName string) models.BotConfig { return models.BotConfig{BotID:botID, BusinessName:botName, BusinessDescription:"Negocio orientado a ventas por WhatsApp.", Offer:"Atención comercial y conversión de leads.", TargetAudience:"Prospectos que llegan por redes o campañas.", Tone:"Profesional, claro y confiable", CTAButtonText:"Quiero avanzar", CTALink:"", FallbackMessage:"Gracias por escribirnos. Te ayudo con gusto. ¿Qué te interesa conocer primero?", HumanHandoffPhone:"", Temperature:0.7, Model:"gpt-4o-mini", FollowupEnabled:true, FollowupDelayMins:60, UpdatedAt: time.Now()} }

func (m *BotManager) CreateBot(clientID,name string) (models.Bot,error) { if strings.TrimSpace(clientID)=="" { return models.Bot{}, fmt.Errorf("client_id is required") }; if _,err:=m.GetClient(clientID); err!=nil { return models.Bot{}, fmt.Errorf("client not found") }; if strings.TrimSpace(name)=="" { name="Bot "+time.Now().Format("20060102150405") }; id:=uuid.NewString(); now:=time.Now(); _,err:=m.MetaDB.Exec(`INSERT INTO bots (id, client_id, name, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?)`, id,clientID,name,"created",now,now); if err!=nil { return models.Bot{}, err }; cfg:=defaultBotConfig(id,name); _,err=m.MetaDB.Exec(`INSERT INTO bot_configs (bot_id, system_prompt, business_name, business_description, offer, target_audience, tone, cta_button_text, cta_link, fallback_message, human_handoff_phone, temperature, model, followup_enabled, followup_delay_mins, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`, cfg.BotID,cfg.SystemPrompt,cfg.BusinessName,cfg.BusinessDescription,cfg.Offer,cfg.TargetAudience,cfg.Tone,cfg.CTAButtonText,cfg.CTALink,cfg.FallbackMessage,cfg.HumanHandoffPhone,cfg.Temperature,cfg.Model,cfg.FollowupEnabled,cfg.FollowupDelayMins,cfg.UpdatedAt); if err!=nil { return models.Bot{}, err }; return m.GetBot(id) }
func (m *BotManager) UpdateBotName(id,name string) error { _, err := m.MetaDB.Exec(`UPDATE bots SET name=?, updated_at=? WHERE id=?`, name, time.Now(), id); return err }
func (m *BotManager) DeleteBot(id string) error { _, err := m.MetaDB.Exec(`DELETE FROM bots WHERE id=?`, id); return err }
func (m *BotManager) GetBot(id string) (models.Bot,error) { var b models.Bot; err:=m.MetaDB.QueryRow(`SELECT id, client_id, name, COALESCE(phone,''), status, COALESCE(last_qr,''), created_at, updated_at FROM bots WHERE id=?`, id).Scan(&b.ID,&b.ClientID,&b.Name,&b.Phone,&b.Status,&b.LastQR,&b.CreatedAt,&b.UpdatedAt); return b,err }
func (m *BotManager) ListBots(clientID string) ([]models.Bot,error) { query:=`SELECT id, client_id, name, COALESCE(phone,''), status, COALESCE(last_qr,''), created_at, updated_at FROM bots`; args:=[]any{}; if strings.TrimSpace(clientID)!="" { query+=` WHERE client_id=?`; args=append(args, clientID)}; query+=` ORDER BY created_at DESC`; rows,err:=m.MetaDB.Query(query,args...); if err!=nil { return nil, err }; defer rows.Close(); out:=[]models.Bot{}; for rows.Next(){ var b models.Bot; if err:=rows.Scan(&b.ID,&b.ClientID,&b.Name,&b.Phone,&b.Status,&b.LastQR,&b.CreatedAt,&b.UpdatedAt); err!=nil { return nil, err }; out=append(out,b)}; return out,nil }

func (m *BotManager) GetBotConfig(botID string) (models.BotConfig,error) { var c models.BotConfig; err:=m.MetaDB.QueryRow(`SELECT bot_id, system_prompt, business_name, business_description, offer, target_audience, tone, cta_button_text, cta_link, fallback_message, human_handoff_phone, temperature, model, followup_enabled, followup_delay_mins, updated_at FROM bot_configs WHERE bot_id=?`, botID).Scan(&c.BotID,&c.SystemPrompt,&c.BusinessName,&c.BusinessDescription,&c.Offer,&c.TargetAudience,&c.Tone,&c.CTAButtonText,&c.CTALink,&c.FallbackMessage,&c.HumanHandoffPhone,&c.Temperature,&c.Model,&c.FollowupEnabled,&c.FollowupDelayMins,&c.UpdatedAt); return c,err }
func (m *BotManager) UpsertBotConfig(cfg models.BotConfig) (models.BotConfig,error) { cfg.UpdatedAt=time.Now(); _,err:=m.MetaDB.Exec(`INSERT INTO bot_configs (bot_id, system_prompt, business_name, business_description, offer, target_audience, tone, cta_button_text, cta_link, fallback_message, human_handoff_phone, temperature, model, followup_enabled, followup_delay_mins, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?) ON CONFLICT(bot_id) DO UPDATE SET system_prompt=excluded.system_prompt,business_name=excluded.business_name,business_description=excluded.business_description,offer=excluded.offer,target_audience=excluded.target_audience,tone=excluded.tone,cta_button_text=excluded.cta_button_text,cta_link=excluded.cta_link,fallback_message=excluded.fallback_message,human_handoff_phone=excluded.human_handoff_phone,temperature=excluded.temperature,model=excluded.model,followup_enabled=excluded.followup_enabled,followup_delay_mins=excluded.followup_delay_mins,updated_at=excluded.updated_at`, cfg.BotID,cfg.SystemPrompt,cfg.BusinessName,cfg.BusinessDescription,cfg.Offer,cfg.TargetAudience,cfg.Tone,cfg.CTAButtonText,cfg.CTALink,cfg.FallbackMessage,cfg.HumanHandoffPhone,cfg.Temperature,cfg.Model,cfg.FollowupEnabled,cfg.FollowupDelayMins,cfg.UpdatedAt); if err!=nil { return models.BotConfig{}, err }; if s,ok:=m.Bots[cfg.BotID]; ok { s.mu.Lock(); s.Config=cfg; s.mu.Unlock() }; return m.GetBotConfig(cfg.BotID) }

func (m *BotManager) StartBot(id string) error {
	m.mu.Lock(); if _,ok:=m.Bots[id]; ok { m.mu.Unlock(); return nil }; m.mu.Unlock()
	bot,err:=m.GetBot(id); if err!=nil { return err }
	cfg,err:=m.GetBotConfig(id); if err!=nil { return err }
	ctx:=context.Background(); botDir:=filepath.Join(m.DataDir,"bots",id); if err:=os.MkdirAll(botDir,0o755); err!=nil { return err }
	logger:=waLog.Stdout("Bot-"+id[:8], "INFO", true)
	container,err:=sqlstore.New(ctx, "sqlite3", "file:"+filepath.Join(botDir,"whatsapp.db")+"?_foreign_keys=on", logger); if err!=nil { return err }
	deviceStore,err:=container.GetFirstDevice(ctx); if err!=nil { if err==sql.ErrNoRows { deviceStore=container.NewDevice() } else { return err } }
	sessionDB,err:=sql.Open("sqlite3", filepath.Join(botDir,"bot.db")); if err!=nil { return err }
	memory:=NewMemoryService(sessionDB); if err:=ensureSessionTables(sessionDB); err!=nil { return err }
	client:=whatsmeow.NewClient(deviceStore, logger)
	session:=&BotSession{ID:id, Name:bot.Name, Status:bot.Status, Phone:bot.Phone, LastQR:bot.LastQR, StoreDB:sessionDB, Client:client, Memory:memory, AI:m.AI, Config:cfg, Logger:logger, MetaDB:m.MetaDB, Templates:m.Templates}
	client.AddEventHandler(func(evt interface{}) { switch e:=evt.(type) { case *events.Connected: session.setStatus("connected"); if client.Store.ID!=nil { session.setPhone(client.Store.ID.User) }; case *events.LoggedOut: session.setStatus("logged_out"); case *events.Message: m.handleIncoming(session,e) } })
	m.mu.Lock(); m.Bots[id]=session; m.mu.Unlock()
	if client.Store.ID==nil { qrChan,_:=client.GetQRChannel(ctx); if err:=client.Connect(); err!=nil { session.setStatus("error"); return err }; go func(){ for evt:= range qrChan { switch evt.Event { case "code": session.setQR(evt.Code); session.setStatus("awaiting_qr"); case "success": session.setQR(""); session.setStatus("connected") } } }() } else { if err:=client.Connect(); err!=nil { session.setStatus("error"); return err }; session.setStatus("connected") }
	return nil
}

func ensureSessionTables(db *sql.DB) error { queries:=[]string{`CREATE TABLE IF NOT EXISTS leads (id INTEGER PRIMARY KEY AUTOINCREMENT, bot_id TEXT NOT NULL, chat_jid TEXT NOT NULL, display_name TEXT, phone TEXT, stage TEXT NOT NULL DEFAULT 'new', last_intent TEXT NOT NULL DEFAULT 'unknown', summary TEXT NOT NULL DEFAULT '', tags TEXT NOT NULL DEFAULT '', last_inbound_text TEXT NOT NULL DEFAULT '', last_reply_text TEXT NOT NULL DEFAULT '', followup_count INTEGER NOT NULL DEFAULT 0, next_followup_at TIMESTAMP, created_at TIMESTAMP NOT NULL, updated_at TIMESTAMP NOT NULL, last_message_at TIMESTAMP, UNIQUE(bot_id, chat_jid));`,`CREATE TABLE IF NOT EXISTS messages (id INTEGER PRIMARY KEY AUTOINCREMENT, bot_id TEXT NOT NULL, chat_jid TEXT NOT NULL, direction TEXT NOT NULL, content TEXT NOT NULL, created_at TIMESTAMP NOT NULL);`}; for _,q:= range queries { if _,err:=db.Exec(q); err!=nil { return err } }; return nil }

func (m *BotManager) handleIncoming(session *BotSession, evt *events.Message) {
	if evt.Info.IsFromMe || evt.Info.Chat.Server=="g.us" || evt.Message==nil { return }
	text := extractText(evt.Message); if strings.TrimSpace(text)=="" { return }
	chatJID:=evt.Info.Chat.String(); phone:=evt.Info.Chat.User; displayName:=phone
	lead,err:=session.Memory.UpsertLead(session.ID, chatJID, displayName, phone, text); if err!=nil { session.Logger.Errorf("memory upsert error: %v", err); return }
	_ = session.Memory.SaveMessage(session.ID, chatJID, "inbound", text)
	tpls, _ := session.Templates.List("")
	promptSnippets := []string{}
	for _, t := range tpls { if t.Stage == lead.Stage && (t.BusinessType == "general" || strings.Contains(strings.ToLower(session.Config.BusinessDescription+" "+session.Config.Offer), strings.ToLower(t.BusinessType))) { if t.PromptSnippet != "" { promptSnippets = append(promptSnippets, t.PromptSnippet) }; if t.MessageTemplate != "" && lead.FollowupCount == 0 && lead.Stage == t.Stage { promptSnippets = append(promptSnippets, "Mensaje sugerido base: "+t.MessageTemplate) } } }
	session.mu.RLock(); cfg:=session.Config; session.mu.RUnlock()
	reply,err:=session.AI.GenerateReply(context.Background(), lead, text, cfg, promptSnippets...); if err!=nil { session.Logger.Warnf("ai error: %v", err); reply=cfg.FallbackMessage }
	_,err=session.Client.SendMessage(context.Background(), evt.Info.Chat, &waProto.Message{Conversation: proto.String(reply)}); if err!=nil { session.Logger.Errorf("send error: %v", err); return }
	_ = session.Memory.SaveReply(session.ID, chatJID, reply); _ = session.Memory.SaveMessage(session.ID, chatJID, "outbound", reply)
}

func extractText(msg *waProto.Message) string { if msg==nil { return "" }; if text:=msg.GetConversation(); text!="" { return text }; if ext:=msg.GetExtendedTextMessage(); ext!=nil { return ext.GetText() }; return "" }
func (m *BotManager) SendText(botID, number, message string) error { session,err:=m.getSession(botID); if err!=nil { return err }; if !session.Client.IsConnected() { return fmt.Errorf("bot is not connected") }; number=strings.TrimPrefix(strings.TrimSpace(number), "+"); jid:=types.NewJID(number, "s.whatsapp.net"); _,err=session.Client.SendMessage(context.Background(), jid, &waProto.Message{Conversation: proto.String(message)}); return err }
func (m *BotManager) SendToLead(botID string, leadID int64, message string) error { session,err:=m.getSession(botID); if err!=nil { return err }; leads,err:=session.Memory.ListLeads(botID); if err!=nil { return err }; var target *models.Lead; for _,l:= range leads { if l.ID==leadID { t:=l; target=&t; break } }; if target==nil { return fmt.Errorf("lead not found") }; jid, err := types.ParseJID(target.ChatJID); if err != nil { return err }; _, err = session.Client.SendMessage(context.Background(), jid, &waProto.Message{Conversation: proto.String(message)}); if err!=nil { return err }; _=session.Memory.SaveReply(botID, target.ChatJID, message); _=session.Memory.SaveMessage(botID, target.ChatJID, "outbound", message); return nil }
func (m *BotManager) getSession(botID string) (*BotSession,error) { m.mu.RLock(); defer m.mu.RUnlock(); s,ok:=m.Bots[botID]; if !ok { return nil, fmt.Errorf("bot session not started") }; return s,nil }
func (m *BotManager) GetQR(botID string) (string,error) { b,err:=m.GetBot(botID); if err!=nil { return "", err }; return b.LastQR,nil }
func (m *BotManager) ListLeads(botID string) ([]models.Lead,error) { s,err:=m.getSession(botID); if err!=nil { botDir:=filepath.Join(m.DataDir,"bots",botID); sessionDB,openErr:=sql.Open("sqlite3", filepath.Join(botDir,"bot.db")); if openErr!=nil { return nil, err }; defer sessionDB.Close(); memory:=NewMemoryService(sessionDB); return memory.ListLeads(botID) }; return s.Memory.ListLeads(botID) }
func (m *BotManager) UpdateLeadStage(botID string, leadID int64, stage string) error { s,err:=m.getSession(botID); if err!=nil { botDir:=filepath.Join(m.DataDir,"bots",botID); sessionDB,openErr:=sql.Open("sqlite3", filepath.Join(botDir,"bot.db")); if openErr!=nil { return err }; defer sessionDB.Close(); return NewMemoryService(sessionDB).UpdateLeadStage(botID, leadID, stage) }; return s.Memory.UpdateLeadStage(botID, leadID, stage) }
func (m *BotManager) LeadMessages(botID string, leadID int64) ([]models.Message, error) { s,err:=m.getSession(botID); if err!=nil { botDir:=filepath.Join(m.DataDir,"bots",botID); sessionDB,_:=sql.Open("sqlite3", filepath.Join(botDir,"bot.db")); defer sessionDB.Close(); mem:=NewMemoryService(sessionDB); leads,_:=mem.ListLeads(botID); for _,l:= range leads { if l.ID==leadID { return mem.ListMessages(botID,l.ChatJID) } }; return []models.Message{}, nil }; leads,_:=s.Memory.ListLeads(botID); for _,l:= range leads { if l.ID==leadID { return s.Memory.ListMessages(botID,l.ChatJID) } }; return []models.Message{}, nil }
func (m *BotManager) Metrics(clientID string) (models.Metrics,error) { metrics:=models.Metrics{}; q1:=`SELECT COUNT(*) FROM clients`; q2:=`SELECT COUNT(*) FROM bots`; args:=[]any{}; if clientID!="" { q1=`SELECT 1`; q2=`SELECT COUNT(*) FROM bots WHERE client_id=?`; args=append(args,clientID) } ; _=m.MetaDB.QueryRow(q1).Scan(&metrics.Clients); _=m.MetaDB.QueryRow(q2,args...).Scan(&metrics.Bots)
	rows, _ := m.ListBots(clientID)
	for _, b := range rows { leads,_ := m.ListLeads(b.ID); metrics.Leads += len(leads); for _, l := range leads { if l.Stage=="hot" { metrics.HotLeads++ }; if l.Stage=="closed" { metrics.ClosedLeads++ } } ; botDir:=filepath.Join(m.DataDir,"bots",b.ID); sessionDB,err:=sql.Open("sqlite3", filepath.Join(botDir,"bot.db")); if err==nil { var c int; _ = sessionDB.QueryRow(`SELECT COUNT(*) FROM messages WHERE created_at >= ?`, time.Now().Add(-24*time.Hour)).Scan(&c); metrics.Messages24h += c; _=sessionDB.Close() } }
	return metrics,nil }
func (m *BotManager) RunFollowupWorker(ctx context.Context) { ticker:=time.NewTicker(2*time.Minute); go func(){ for { select { case <-ctx.Done(): return; case <-ticker.C: m.processFollowups() } } }() }
func (m *BotManager) processFollowups() { m.mu.RLock(); sessions:=make([]*BotSession,0,len(m.Bots)); for _,s := range m.Bots { sessions = append(sessions,s) }; m.mu.RUnlock(); now:=time.Now(); for _,s := range sessions { s.mu.RLock(); cfg:=s.Config; s.mu.RUnlock(); if !cfg.FollowupEnabled || cfg.FollowupDelayMins <= 0 { continue }; leads,err:=s.Memory.DueFollowups(now); if err!=nil { continue }; for _,lead := range leads { if lead.FollowupCount >= 3 { _ = s.Memory.UpdateLeadStage(s.ID, lead.ID, "lost"); continue }; msg:=fmt.Sprintf("Hola 👋 solo quería hacer seguimiento. %s %s", cfg.CTAButtonText, cfg.CTALink); jid,err:=types.ParseJID(lead.ChatJID); if err!=nil { continue }; _, err = s.Client.SendMessage(context.Background(), jid, &waProto.Message{Conversation: proto.String(msg)}); if err==nil { _=s.Memory.SaveReply(s.ID, lead.ChatJID, msg); _=s.Memory.SaveMessage(s.ID, lead.ChatJID, "outbound", msg); _=s.Memory.MarkFollowupSent(s.ID, lead.ID, cfg.FollowupDelayMins) } } } }
func (s *BotSession) setQR(code string) { s.mu.Lock(); s.LastQR=code; s.mu.Unlock(); _,_=s.MetaDB.Exec(`UPDATE bots SET last_qr=?, updated_at=? WHERE id=?`, code,time.Now(),s.ID) }
func (s *BotSession) setStatus(status string) { s.mu.Lock(); s.Status=status; s.mu.Unlock(); _,_=s.MetaDB.Exec(`UPDATE bots SET status=?, updated_at=? WHERE id=?`, status,time.Now(),s.ID) }
func (s *BotSession) setPhone(phone string) { s.mu.Lock(); s.Phone=phone; s.mu.Unlock(); _,_=s.MetaDB.Exec(`UPDATE bots SET phone=?, updated_at=? WHERE id=?`, phone,time.Now(),s.ID) }
